# =============================================================================
# dental-3dgs-lab — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# -----------------------------------------------------------------------------
# Entornos virtuales
# -----------------------------------------------------------------------------
.venv/
venv/
env/
.env/

# -----------------------------------------------------------------------------
# Variables de entorno y secretos
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
secrets/

# -----------------------------------------------------------------------------
# Datos
# -----------------------------------------------------------------------------
# No se versionan por tres motivos: (1) pesan (Teeth3DS+ son ~7,9 GB de mallas),
# (2) reproducibilidad — se regeneran desde su origen, no se guardan en git:
#     - data/raw/       = Teeth3DS+ tal cual se descarga
#     - data/processed/ = artefactos derivados (vistas, transforms.json, .ply)
#                         -> los generan los notebooks 03 y 04 al ejecutarse
# (3) licencia del dato: no redistribuir el dataset a través del repo.
data/raw/
data/processed/
data/external/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Artefactos 3DGS y modelos
# -----------------------------------------------------------------------------
*.ply
*.splat
*.ckpt
*.pt
*.pth
*.safetensors

# -----------------------------------------------------------------------------
# Testing, linting, type checking
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.claude/settings.local.json

# -----------------------------------------------------------------------------
# SO
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs y temporales
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
tmp/
temp/
